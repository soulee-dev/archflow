{
  "scopeName": "source.archflow",
  "patterns": [
    { "include": "#comment" },
    { "include": "#use-statement" },
    { "include": "#metadata" },
    { "include": "#cluster" },
    { "include": "#edge-operator" },
    { "include": "#edge-label" },
    { "include": "#provider-node" },
    { "include": "#brackets" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "match": "#.*$",
          "name": "comment.line.number-sign.archflow"
        },
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.archflow"
        }
      ]
    },
    "use-statement": {
      "match": "^\\s*(use)\\s+([a-z][a-z0-9-]*)(?:\\s+(from)\\s+(.+))?\\s*$",
      "captures": {
        "1": { "name": "keyword.control.use.archflow" },
        "2": { "name": "entity.name.type.provider.archflow" },
        "3": { "name": "keyword.control.from.archflow" },
        "4": { "name": "string.unquoted.source.archflow" }
      }
    },
    "metadata": {
      "match": "^\\s*(title|direction|theme)\\s*(:)\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.other.metadata.archflow" },
        "2": { "name": "punctuation.separator.archflow" },
        "3": { "name": "string.unquoted.value.archflow" }
      }
    },
    "cluster": {
      "match": "^\\s*(cluster)(?:(:)([a-z][a-z0-9-]*)(:)([a-z][a-z0-9-]*))?\\s+(.+?)\\s*(\\{)\\s*$",
      "captures": {
        "1": { "name": "keyword.control.cluster.archflow" },
        "2": { "name": "punctuation.separator.archflow" },
        "3": { "name": "entity.name.type.provider.archflow" },
        "4": { "name": "punctuation.separator.archflow" },
        "5": { "name": "entity.name.type.cluster-type.archflow" },
        "6": { "name": "entity.name.class.cluster-label.archflow" },
        "7": { "name": "punctuation.section.block.begin.archflow" }
      }
    },
    "edge-operator": {
      "match": ">>",
      "name": "keyword.operator.edge.archflow"
    },
    "edge-label": {
      "match": "\\[([^\\]]+)\\]",
      "captures": {
        "0": { "name": "string.quoted.bracket.archflow" },
        "1": { "name": "string.unquoted.edge-label.archflow" }
      }
    },
    "provider-node": {
      "match": "\\b([a-z][a-z0-9-]*)(:)([A-Za-z][A-Za-z0-9-]*)\\b",
      "captures": {
        "1": { "name": "entity.name.type.provider.archflow" },
        "2": { "name": "punctuation.separator.archflow" },
        "3": { "name": "entity.name.function.icon.archflow" }
      }
    },
    "brackets": {
      "patterns": [
        { "match": "[{}]", "name": "punctuation.section.block.archflow" }
      ]
    }
  }
}
